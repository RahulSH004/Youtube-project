// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  username         String
  email            String         @unique @default("")
  password         String
  gender           Gender
  ChannelName      String
  ChannelThumbnail String?
  Banner           String?
  ProfilePicture   String?
  SubscriberCount  Int            @default(0)
  Description      String?
  uploads          Uploads[]
  likes            Like[]
  subscription     Subscription[]
  name             String
  emailVerified    Boolean        @default(false)
  image            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sessions         Session[]

  @@map("user")
}

model Uploads {
  id        String     @id @default(cuid())
  title     String
  slug      String    @unique
  videoUrl  String
  videoPublicId String  @unique
  status        VideoStatus @default(PROCESSING)
  Thumbnail String?
  type      UploadType @default(PUBLIC)
  description String?
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  likes     Like[]
}

model Like {
  id       String  @id @default(cuid())
  userId   String
  uploadId String
  user     User    @relation(fields: [userId], references: [id])
  upload   Uploads @relation(fields: [uploadId], references: [id])

  @@unique([userId, uploadId])
}

model Subscription {
  id            String @id @default(cuid())
  subscriberId  String
  channelUserId String
  subscriber    User   @relation(fields: [subscriberId], references: [id])

  @@unique([subscriberId, channelUserId])
}

enum Gender {
  Male
  Female
  Others
}

enum UploadType {
  PUBLIC
  PRIVATE
  UNLISTED
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
}